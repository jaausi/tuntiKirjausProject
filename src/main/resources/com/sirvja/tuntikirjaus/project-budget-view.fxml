<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="380.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sirvja.tuntikirjaus.controller.ProjectBudgetViewController">
   <padding>
      <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
   </padding>
   <children>
      <Label text="Projektibudjetit – kuluva kuukausi" style="-fx-font-weight: bold; -fx-font-size: 14;" />
      <Label text="Syötä budjetti tunteina (esim. 40 tai 37.5). Tyhjä = ei budjettia." style="-fx-font-size: 11; -fx-text-fill: grey;" />
      <TableView fx:id="budgetTable" editable="true" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="projectColumn" text="Projekti" prefWidth="200.0" />
            <TableColumn fx:id="budgetColumn" text="Budjetti (h)" prefWidth="130.0" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <HBox alignment="CENTER_RIGHT" spacing="8.0">
         <children>
            <Button text="Sulje" onAction="#onCloseButtonClick" />
         </children>
      </HBox>
   </children>
</VBox>

